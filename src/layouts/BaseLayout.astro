---
import "@styles/global.css";

interface Props {
  title?: string;
  description?: string;
}

const {
  title = "Caston McDonald",
  description = "Applied AI Engineer/Consultant and Systems Engineering Student.",
} = Astro.props;

const base = import.meta.env.BASE_URL.endsWith("/")
  ? import.meta.env.BASE_URL
  : `${import.meta.env.BASE_URL}/`;
const withBase = (path: string) => `${base}${path.replace(/^\//, "")}`;
const navItems = [
  { href: withBase("/"), label: "Home" },
  { href: withBase("/blog/"), label: "Blog" },
  { href: withBase("/projects/"), label: "Projects" },
  { href: withBase("/about/"), label: "About" },
];
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="description" content={description} />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href={withBase("/favicon.svg")} />
    <title>{title}</title>
  </head>
  <body>
    <header class="site-header">
      <nav class="container nav" aria-label="Primary navigation">
        <a class="brand" href={withBase("/")}>
          <span>Caston McDonald</span>
        </a>
        <div class="nav-links">
          {navItems.map((item) => <a href={item.href}>{item.label}</a>)}
        </div>
      </nav>
    </header>
    <main>
      <slot />
    </main>
    <footer class="site-footer">
      <div class="container footer-inner">
        <p>Applied AI Engineer/Consultant, Systems Engineering Student.</p>
        <a href="https://x.com/CastonMcD">Follow @CastonMcD</a>
      </div>
    </footer>
  </body>
</html>

<style>
  .site-header {
    position: sticky;
    top: 0;
    z-index: 10;
    border-bottom: 1px solid color-mix(in srgb, var(--border) 82%, transparent);
    background: color-mix(in srgb, var(--bg) 92%, transparent);
    backdrop-filter: blur(14px);
  }

  .nav {
    display: flex;
    min-height: 68px;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
  }

  .brand {
    font-weight: 800;
    text-decoration: none;
  }

  .nav-links {
    display: flex;
    flex-wrap: wrap;
    gap: 0.35rem;
    justify-content: flex-end;
  }

  .nav-links a {
    border-radius: 999px;
    padding: 0.45rem 0.75rem;
    color: var(--muted);
    font-size: 0.95rem;
    text-decoration: none;
  }

  .nav-links a:hover {
    background: var(--accent-soft);
    color: var(--accent);
  }

  .site-footer {
    border-top: 1px solid var(--border);
    padding: 28px 0;
  }

  .footer-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    color: var(--muted);
    font-size: 0.95rem;
  }

  .footer-inner p {
    margin: 0;
  }

  @media (max-width: 680px) {
    .nav,
    .footer-inner {
      align-items: flex-start;
      flex-direction: column;
    }
  }
</style>
