---
import "@styles/global.css";

interface Props {
  title?: string;
  description?: string;
}

const {
  title = "Caston McDonald",
  description = "MSCS at Georgia Tech, applied enterprise AI, technical consulting, and systems thinking.",
} = Astro.props;

const base = import.meta.env.BASE_URL.endsWith("/")
  ? import.meta.env.BASE_URL
  : `${import.meta.env.BASE_URL}/`;
const withBase = (path: string) => `${base}${path.replace(/^\//, "")}`;
const navItems = [
  { href: withBase("/"), label: "Home" },
  { href: withBase("/posts/"), label: "Posts" },
  { href: withBase("/about/"), label: "About" },
];
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="description" content={description} />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href={withBase("/favicon.svg")} />
    <title>{title}</title>
  </head>
  <body>
    <header class="site-header">
      <nav class="container nav" aria-label="Primary navigation">
        <a class="brand" href={withBase("/")}>
          <span>Caston McDonald</span>
        </a>
        <div class="nav-links">
          {navItems.map((item) => <a href={item.href}>{item.label}</a>)}
        </div>
      </nav>
    </header>
    <main>
      <slot />
    </main>
    <footer class="site-footer">
      <div class="container footer-grid">
        <div>
          <a class="footer-brand" href={withBase("/")}>Caston McDonald</a>
          <p>Enterprise AI, systems thinking, and technical learning.</p>
        </div>
        <div class="footer-links" aria-label="Footer navigation">
          {navItems.map((item) => <a href={item.href}>{item.label}</a>)}
        </div>
        <div class="footer-links" aria-label="Social links">
          <a href="https://github.com/CastonM">GitHub</a>
          <a href="https://x.com/CastonMcD">X</a>
        </div>
        <p class="copyright">© {new Date().getFullYear()} Caston McDonald.</p>
      </div>
    </footer>
  </body>
</html>

<style>
  .site-header {
    position: sticky;
    top: 0;
    z-index: 10;
    border-bottom: 1px solid color-mix(in srgb, var(--border) 82%, transparent);
    background: color-mix(in srgb, var(--bg) 92%, transparent);
    backdrop-filter: blur(14px);
  }

  .nav {
    display: flex;
    min-height: 68px;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
  }

  .brand {
    font-weight: 800;
    text-decoration: none;
  }

  .nav-links {
    display: flex;
    flex-wrap: wrap;
    gap: 0.35rem;
    justify-content: flex-end;
  }

  .nav-links a {
    border-radius: 999px;
    padding: 0.45rem 0.75rem;
    color: var(--muted);
    font-size: 0.95rem;
    text-decoration: none;
  }

  .nav-links a:hover {
    background: var(--accent-soft);
    color: var(--accent);
  }

  .site-footer {
    border-top: 1px solid var(--border);
    padding: 32px 0;
  }

  .footer-grid {
    display: grid;
    grid-template-columns: minmax(240px, 1fr) auto auto;
    gap: 1rem;
    align-items: start;
    color: var(--muted);
    font-size: 0.95rem;
  }

  .footer-brand {
    display: inline-block;
    color: var(--text);
    font-weight: 800;
    text-decoration: none;
  }

  .footer-grid p {
    margin: 0.35rem 0 0;
  }

  .footer-links {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
    justify-content: flex-end;
  }

  .footer-links a {
    color: var(--muted);
    text-decoration: none;
  }

  .footer-links a:hover {
    color: var(--accent);
  }

  .copyright {
    grid-column: 1 / -1;
    padding-top: 1rem;
    border-top: 1px solid color-mix(in srgb, var(--border) 72%, transparent);
    font-size: 0.86rem;
  }

  @media (max-width: 680px) {
    .nav,
    .footer-grid {
      align-items: flex-start;
      flex-direction: column;
    }

    .footer-grid {
      display: flex;
    }

    .footer-links {
      justify-content: flex-start;
    }
  }
</style>
