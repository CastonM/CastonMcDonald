---
import { getCollection } from "astro:content";
import BaseLayout from "@layouts/BaseLayout.astro";
import PostCard from "@components/PostCard.astro";
import ProjectCard from "@components/ProjectCard.astro";
import XFeed from "@components/XFeed.astro";

const posts = (await getCollection("blog"))
  .filter((post) => !post.data.draft)
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .slice(0, 3);

const projects = (await getCollection("projects")).slice(0, 3);
const base = import.meta.env.BASE_URL.endsWith("/")
  ? import.meta.env.BASE_URL
  : `${import.meta.env.BASE_URL}/`;
const withBase = (path: string) => `${base}${path.replace(/^\//, "")}`;
---

<BaseLayout
  title="Caston McDonald | Applied AI Engineer"
  description="Applied AI Engineer/Consultant and Systems Engineering Student."
>
  <section class="hero">
    <div class="container hero-inner">
      <p class="eyebrow">Applied AI Engineer/Consultant, Systems Engineering Student</p>
      <h1>Building useful AI systems and documenting the work in public.</h1>
      <p>
        I use this site as a home base for live reflections, longer notes, and
        the projects I am shaping across applied AI, consulting, and systems
        engineering.
      </p>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <XFeed />
    </div>
  </section>

  <section class="section recent-work">
    <div class="container">
      <div class="section-header">
        <div>
          <p class="eyebrow">Recent Work</p>
          <h2>Projects in motion</h2>
          <p>Selected work areas and experiments that will become more detailed over time.</p>
        </div>
        <a href={withBase("/projects/")}>All projects</a>
      </div>
      <div class="card-grid">
        {
          projects.map((project) => (
            <ProjectCard
              title={project.data.title}
              description={project.data.description}
              status={project.data.status}
              tech={project.data.tech}
              repoUrl={project.data.repoUrl}
              demoUrl={project.data.demoUrl}
            />
          ))
        }
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="section-header">
        <div>
          <p class="eyebrow">Blog</p>
          <h2>Longer notes</h2>
          <p>Posts for ideas that need more room than a timeline.</p>
        </div>
        <a href={withBase("/blog/")}>All posts</a>
      </div>
      <div class="card-grid">
        {
          posts.map((post) => (
            <PostCard
              title={post.data.title}
              description={post.data.description}
              date={post.data.date}
              href={withBase(`/blog/${post.slug}/`)}
              tags={post.data.tags}
            />
          ))
        }
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .hero {
    border-bottom: 1px solid var(--border);
    padding: 82px 0 64px;
  }

  .hero-inner {
    max-width: 940px;
  }

  h1 {
    max-width: 11ch;
    margin: 0;
    font-size: clamp(3rem, 9vw, 7.4rem);
    line-height: 0.92;
  }

  .hero p:last-child {
    max-width: 680px;
    color: var(--muted);
    font-size: clamp(1.08rem, 2vw, 1.32rem);
  }

  .recent-work {
    border-block: 1px solid var(--border);
    background: color-mix(in srgb, var(--surface) 58%, var(--bg));
  }
</style>
