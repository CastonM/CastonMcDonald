---
import { getCollection } from "astro:content";
import BaseLayout from "@layouts/BaseLayout.astro";
import PostCard from "@components/PostCard.astro";

const posts = (await getCollection("posts"))
  .filter((post) => !post.data.draft)
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .slice(0, 3);

const base = import.meta.env.BASE_URL.endsWith("/")
  ? import.meta.env.BASE_URL
  : `${import.meta.env.BASE_URL}/`;
const withBase = (path: string) => `${base}${path.replace(/^\//, "")}`;
---

<BaseLayout
  title="Caston McDonald"
  description="MSCS at Georgia Tech, applied enterprise AI, technical consulting, and systems thinking."
>
  <section class="home">
    <div class="container">
      <header class="intro">
        <h1>Caston McDonald</h1>
        <p>
          About me: My day job is at EY's AI, Data, and Engineering practice, I am in a part time MS CS degree at Georgia Tech, and use this
          site as my home base for the things I am learning and building.
        </p>
      </header>

      <nav class="home-links" aria-label="Primary links">
        <a href={withBase("/about/")}>About</a>
        <a href={withBase("/posts/")}>Posts</a>
        <a href="https://github.com/CastonM">GitHub</a>
        <a href="https://x.com/CastonMcD">X</a>
      </nav>

      <section class="index-section">
        <h2>Work</h2>
        <p>
          Enterprise AI and Product Development.
        </p>
      </section>

      <section class="index-section">
        <h2>School</h2>
        <p>
          MSCS at Georgia Tech with a systems focus. Currently taking High
          Performance Computing and GPU Hardware/Software.
        </p>
      </section>

      <section class="index-section">
        <div class="section-title-row">
          <h2>Posts</h2>
          <a href={withBase("/posts/")}>All posts</a>
        </div>
        {
          posts.map((post) => (
            <PostCard
              title={post.data.title}
              description={post.data.description}
              date={post.data.date}
              href={withBase(`/posts/${post.slug}/`)}
            />
          ))
        }
      </section>
    </div>
  </section>
</BaseLayout>

<style>
  .home {
    padding: 42px 0 58px;
  }

  .intro {
    max-width: 680px;
  }

  .intro h1 {
    margin: 0;
    font-size: clamp(1.7rem, 4vw, 2.45rem);
    line-height: 1.1;
    letter-spacing: 0;
  }

  .intro p {
    margin: 0.9rem 0 0;
    color: var(--muted);
    font-size: 1.05rem;
  }

  .home-links {
    display: flex;
    flex-wrap: wrap;
    gap: 1rem;
    margin-top: 1.4rem;
  }

  .home-links a {
    color: var(--text);
    font-size: 0.96rem;
  }

  .index-section {
    display: grid;
    grid-template-columns: 9.5rem minmax(0, 1fr);
    gap: 1rem;
    border-top: 1px solid var(--border);
    padding: 1.2rem 0;
    margin-top: 1.6rem;
  }

  .index-section + .index-section {
    margin-top: 0;
  }

  .index-section h2 {
    margin: 0;
    font-size: 1rem;
    line-height: 1.4;
  }

  .index-section p {
    margin: 0;
    color: var(--muted);
  }

  .section-title-row {
    display: contents;
  }

  .section-title-row a {
    justify-self: end;
    color: var(--muted);
    font-size: 0.94rem;
  }

  .index-section :global(.post-card) {
    grid-column: 2;
  }

  @media (max-width: 640px) {
    .index-section {
      grid-template-columns: 1fr;
      gap: 0.4rem;
    }

    .section-title-row {
      display: flex;
      align-items: center;
      justify-content: space-between;
    }

    .index-section :global(.post-card) {
      grid-column: auto;
    }
  }
</style>
